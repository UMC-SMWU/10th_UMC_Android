<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/ic_homeItem"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:src="@drawable/home_item1"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvHomeItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="15dp"
        android:layout_marginStart="50dp"
        android:text="Air Jordan XXXVI"
        app:layout_constraintTop_toBottomOf="@+id/ic_homeItem"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvHomePrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="@color/grey"
        android:layout_marginTop="8dp"
        android:layout_marginStart="50dp"
        android:text="US$185"
        app:layout_constraintTop_toBottomOf="@+id/tvHomeItem"
        app:layout_constraintStart_toStartOf="parent"/>



</androidx.constraintlayout.widget.ConstraintLayout>