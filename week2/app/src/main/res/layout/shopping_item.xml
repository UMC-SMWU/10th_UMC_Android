<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/ic_shoppingItem"
        android:layout_width="190dp"
        android:layout_height="190dp"
        android:src="@drawable/home_item1"

        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        />

    <ImageView
        android:id="@+id/btnLike"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:padding="10dp"

        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_circle"
        android:src="@drawable/ic_emptyheart"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <TextView
        android:id="@+id/tvShoppingItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@+id/ic_shoppingItem"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvShoppingCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="@color/grey"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@+id/tvShoppingItem"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvShoppingColor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="@color/grey"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@+id/tvShoppingCategory"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvShoppingPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@+id/tvShoppingColor"
        app:layout_constraintStart_toStartOf="parent"/>



</androidx.constraintlayout.widget.ConstraintLayout>